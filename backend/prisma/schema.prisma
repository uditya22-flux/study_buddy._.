generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
 
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String?   // Added for auth
  name        String
  avatarEmoji String    @default("📚")
  theme       String    @default("light")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  folders     Folder[]
  sessions    Session[]
  reminders   Reminder[]
  studySessions StudySession[]
}

model Folder {
  id          String    @id @default(cuid())
  name        String
  color       String    @default("blue")
  icon        String    @default("📁")
  userId      String
  parentId    String?
  isPinned    Boolean   @default(false)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent      Folder?   @relation("FolderChildren", fields: [parentId], references: [id])
  children    Folder[]  @relation("FolderChildren")
  notes       Note[]
  files       File[]

  @@index([userId])
  @@index([parentId])
}

model Note {
  id          String    @id @default(cuid())
  title       String    @default("Untitled")
  content     Json      @default("{}")
  folderId    String
  userId      String
  isPinned    Boolean   @default(false)
  wordCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  folder      Folder    @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([folderId])
  @@index([userId])
}

model File {
  id          String    @id @default(cuid())
  name        String
  url         String
  mimeType    String
  size        Int
  folderId    String
  userId      String
  createdAt   DateTime  @default(now())
  folder      Folder    @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([folderId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model StudySession {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @default(now())
  durationMin Int
  topicsCount Int      @default(0)
  notesAdded  Int      @default(0)
  user        User     @relation(fields: [userId], references: [id])
}

model Reminder {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String?
  dueAt     DateTime
  sent      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id])
}
